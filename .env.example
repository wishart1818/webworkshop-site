NEXT_PUBLIC_SITE_URL=https://webworkshop.dev

# Required in production to access /engine and /api/engine.
# Keep these server-only. Never prefix them with NEXT_PUBLIC_.
ENGINE_USERNAME=operator
ENGINE_PASSWORD=replace-with-a-long-random-password

# Recommended for Vercel runtime: a Neon pooled connection string with sslmode=require.
# Use Neon's direct connection string temporarily when running prisma migrate deploy.
# When omitted, public routes still work. The engine uses non-durable memory only in development
# and its prospect APIs fail closed in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler:5432/webworkshop?schema=public&sslmode=require

# Optional provider overrides for user-triggered lead discovery.
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/search
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Optional licensed enrichment sources. The engine never scrapes search-result pages.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_API_URL=https://places.googleapis.com/v1/places:searchText
# Azure Maps POI Search is the preferred current Microsoft local-search source.
AZURE_MAPS_API_KEY=
AZURE_MAPS_POI_API_URL=https://atlas.microsoft.com/search/poi/json
# Legacy Bing Maps Local Search works only for eligible enterprise accounts until June 30, 2028.
BING_MAPS_API_KEY=
BING_LOCAL_API_URL=https://dev.virtualearth.net/REST/v1/LocalSearch/
YELP_API_KEY=
YELP_API_URL=https://api.yelp.com/v3/businesses/search
# Approved/licensed directory endpoint returning businesses, results, or records.
YELLOW_PAGES_API_URL=
YELLOW_PAGES_API_KEY=

# Optional internal-only notification when a manual Loom task is created.
# Requires RESEND_API_KEY if you want the app to send the notification.
OUTREACH_NOTIFY_EMAIL=
OUTREACH_NOTIFY_FROM_EMAIL=
OUTREACH_NOTIFY_ON_LOOM_NEEDED=false

# Optional Operator Test Center/internal alerts.
# These only send to INTERNAL_NOTIFY_EMAIL and never to prospects.
INTERNAL_NOTIFICATIONS_ENABLED=false
INTERNAL_NOTIFY_EMAIL=
INTERNAL_NOTIFY_FROM_EMAIL=

# Optional Operator Test Center/internal SMS alerts through Twilio.
# These only send to INTERNAL_NOTIFY_PHONE and never to prospects or lead phone numbers.
SMS_NOTIFICATIONS_ENABLED=false
INTERNAL_NOTIFY_PHONE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Required before marking email outreach packages send-ready.
# Prospect Engine and Top Prospects use this value for manual email draft compliance/readiness.
# This is inserted into manual email drafts; no outreach is sent automatically.
WEBWORKSHOP_POSTAL_ADDRESS=

# Optional Auto Email Pilot/provider readiness address.
# Prospect Engine manual outreach uses WEBWORKSHOP_POSTAL_ADDRESS above. Keep this only if you later configure
# the separate Auto Email Pilot provider gates; it does not replace WEBWORKSHOP_POSTAL_ADDRESS.
OUTREACH_POSTAL_ADDRESS=

# Auto Email Pilot is off unless every value below is configured and Autonomous Growth mode is explicitly
# switched to Auto Email Pilot with its in-app kill switch off. Only Queued public-email leads can send.
# Emergency hard stop for email sending. Set true to block human-approved and full-auto email sends.
OUTREACH_EMAIL_DISABLED=false
OUTREACH_AUTO_SEND_ENABLED=false
# Optional second switch for fully automatic queued-email batches. Leave false unless you intentionally
# want the app to send already-Queued public-email items without clicking Send approved email one by one.
OUTREACH_FULL_AUTO_SEND_ENABLED=false
OUTREACH_SEND_PROVIDER=resend
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO_EMAIL=
OUTREACH_DAILY_CAP=5
# Optional token for provider bounce/complaint/unsubscribe suppression events.
# Requests to /api/engine/outreach-events are rejected unless this token is configured and supplied.
OUTREACH_SUPPRESSION_WEBHOOK_TOKEN=

# Optional hard server-side Autopilot kill switch.
# Set to true in Production to prevent new Autopilot runs/handoffs while keeping manual review available.
AUTOPILOT_DISABLED=false
