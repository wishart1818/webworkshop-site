NEXT_PUBLIC_SITE_URL=https://webworkshop.dev

# Required in production to access /engine and /api/engine.
# Keep these server-only. Never prefix them with NEXT_PUBLIC_.
ENGINE_USERNAME=operator
ENGINE_PASSWORD=replace-with-a-long-random-password

# Recommended for Vercel runtime: a Neon pooled connection string with sslmode=require.
# Use Neon's direct connection string temporarily when running prisma migrate deploy.
# When omitted, public routes still work. The engine uses non-durable memory only in development
# and its prospect APIs fail closed in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler:5432/webworkshop?schema=public&sslmode=require

# Optional provider overrides for user-triggered lead discovery.
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/search
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
