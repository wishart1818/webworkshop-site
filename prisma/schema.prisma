generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProspectStatus {
  NEW
  REVIEWED
  CONTACTED
  INTERESTED
  PROPOSAL_SENT
  CLOSED_WON
  CLOSED_LOST
}

model Prospect {
  id            String          @id @default(cuid())
  businessName  String
  website       String?         @unique
  profileUrl    String?
  prospectType  String          @default("redesign")
  classification String         @default("not_enough_contact_info")
  phone         String?
  publicEmail   String?
  contactPageUrl String?
  contactFormUrl String?
  quoteFormUrl String?
  contactFormDetected Boolean @default(false)
  quoteFormDetected Boolean @default(false)
  facebookUrl   String?
  instagramUrl  String?
  linkedinUrl   String?
  xUrl          String?
  youtubeUrl    String?
  contactPersonName String?
  contactConfidence String @default("low")
  bestManualContactMethod String @default("unknown")
  contactDiscoveryNotes Json @default("[]")
  address       String?
  city          String
  state         String
  tradeCategory String
  serviceArea   String?
  sizeIndicator String?
  priorityScore Int             @default(0)
  rating        Float           @default(0)
  reviewCount   Int             @default(0)
  recentReviewCount Int         @default(0)
  sourceConfidence Int          @default(0)
  activitySignals Json          @default("[]")
  recommendedContactMethod String @default("needs_manual_contact_research")
  inactive      Boolean         @default(false)
  websiteStatus String          @default("unknown")
  websiteStatusDetail String?
  websiteAnalysisAttemptedAt DateTime?
  status        ProspectStatus  @default(NEW)
  analyses      Analysis[]
  outreach      OutreachDraft[]
  previews      PreviewConcept[]
  notes         Note[]
  activities    Activity[]
  statusHistory StatusHistory[]
  topProspectResults TopProspectResult[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, priorityScore])
  @@index([tradeCategory, state, city])
  @@index([prospectType, priorityScore])
}

model TopProspectJob {
  id                String              @id @default(cuid())
  tradeCategory     String
  city              String
  state             String
  radiusKm          Int
  businessesToScan  Int                 @default(50)
  finalProspectsWanted Int              @default(10)
  prospectMode      String              @default("strict")
  prospectType      String              @default("redesign")
  workflowType      String              @default("search")
  outreachPreference String             @default("written_only")
  status            String              @default("QUEUED")
  stage             String              @default("DISCOVER")
  discoveredLeads   Json?
  nextLeadIndex     Int                 @default(0)
  scannedCount      Int                 @default(0)
  qualifiedCount    Int                 @default(0)
  skippedCount      Int                 @default(0)
  skipSummary       Json?
  errorMessage      String?
  leaseToken        String?
  leaseUntil        DateTime?
  results           TopProspectResult[]
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([prospectType, createdAt])
}

model TopProspectResult {
  id               String         @id @default(cuid())
  jobId            String
  job              TopProspectJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  prospectId       String
  prospect         Prospect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  rank             Int?
  selected         Boolean        @default(false)
  opportunityScore Int
  websiteQualityScore Int         @default(0)
  revenueOpportunityScore Int     @default(0)
  contactabilityScore Int         @default(0)
  localMarketCompetitivenessScore Int @default(0)
  aiReplacementConfidenceScore Int @default(0)
  weightedSalesScore Int          @default(0)
  prospectType      String        @default("redesign")
  onlinePresenceGapScore Int      @default(0)
  businessActivityScore Int       @default(0)
  websiteNeedScore  Int           @default(0)
  mainWeakness     String
  whyMayBuy        String
  pitchAngle       String
  buildPrompt      String
  packageStatus    String         @default("NOT_GENERATED")
  previewLink      String         @default("")
  publicPreviewToken String?      @unique
  packageGeneratedAt DateTime?
  packageReviewedAt DateTime?
  packageApprovedAt DateTime?
  packageSentAt    DateTime?
  packageSkippedAt DateTime?
  createdAt        DateTime       @default(now())

  @@unique([jobId, prospectId])
  @@index([jobId, selected, rank])
  @@index([jobId, weightedSalesScore])
  @@index([prospectId, createdAt])
  @@index([packageStatus, createdAt])
}

model AutonomousGrowthSettings {
  id                         String   @id @default("default")
  mode                       String   @default("off")
  killSwitch                 Boolean  @default(true)
  targetCities               Json     @default("[]")
  targetServiceAreas         Json     @default("[]")
  targetTrades               Json     @default("[]")
  excludedTrades             Json     @default("[]")
  maxProspectsScannedPerDay  Int      @default(25)
  maxPreviewsGeneratedPerDay Int      @default(10)
  maxEmailsQueuedPerDay      Int      @default(5)
  maxEmailsSentPerDay        Int      @default(5)
  emailCooldownMinutes       Int      @default(7)
  followUpsEnabled           Boolean  @default(false)
  styleProfiles              Json     @default("{}")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model OutreachQueueItem {
  id                  String   @id @default(cuid())
  prospectId          String?
  topProspectResultId String?
  businessName        String
  trade               String
  city                String
  website             String?
  email               String?
  contactSource       String
  contactConfidence   Int      @default(0)
  previewLink         String
  previewQualityScore Int      @default(0)
  subjectLine         String
  emailBody           String
  dmScript            String
  loomTalkingPoints   String
  eligibilityReason   String
  blockedReason       String?
  reviewScore         Int      @default(0)
  reviewSummary       String   @default("")
  improvementSuggestions Json  @default("[]")
  detectedIssues      Json     @default("[]")
  recommendedNextAction String @default("Needs Human Review")
  regenerationPlan    Json     @default("[]")
  rewritePlan         Json     @default("[]")
  feedbackLabels      Json     @default("[]")
  status              String   @default("Draft")
  sourceProvider      String?
  queuedDate          DateTime?
  sentDate            DateTime?
  followUpDate        DateTime?
  replyStatus         String?
  notes               String?
  outreachCopyVersion String   @default("")
  outreachCopyGeneratedAt DateTime?
  previewVersion      String   @default("")
  lastRegeneratedAt   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([topProspectResultId])
  @@index([status, createdAt])
  @@index([trade, city])
  @@index([prospectId])
}

model AutonomousFeedbackEvent {
  id                  String   @id @default(cuid())
  queueItemId         String
  topProspectResultId String?
  businessName        String
  trade               String
  city                String
  feedbackLabel       String
  feedbackCategory    String
  note                String?
  createdAt           DateTime @default(now())

  @@index([queueItemId, createdAt])
  @@index([trade, city])
  @@index([feedbackLabel, createdAt])
}

model AutonomousLearningEvent {
  id                  String   @id @default(cuid())
  queueItemId         String
  topProspectResultId String?
  trade               String
  city                String
  leadSource          String
  previewStyle        String
  subjectLineAngle    String
  outreachAngle       String
  contactMethod       String
  previewQualityScore Int
  reviewScore         Int      @default(0)
  replyStatus         String?
  positiveReplyStatus String?
  lostReason          String?
  manualNote          String?
  feedbackLabels      Json     @default("[]")
  createdAt           DateTime @default(now())

  @@index([trade, city])
  @@index([leadSource, createdAt])
  @@index([previewStyle, createdAt])
  @@index([createdAt])
}

model AutonomousRunReview {
  id                         String   @id @default(cuid())
  mode                       String
  prospectsScanned           Int      @default(0)
  prospectsKept              Int      @default(0)
  prospectsBlocked           Int      @default(0)
  previewsGenerated          Int      @default(0)
  previewsPassed             Int      @default(0)
  previewsFailed             Int      @default(0)
  commonPreviewIssues        Json     @default("[]")
  commonLeadIssues           Json     @default("[]")
  outreachQualityNotes       Json     @default("[]")
  recommendedFixes           Json     @default("[]")
  summary                    String
  createdAt                  DateTime @default(now())

  @@index([mode, createdAt])
}

model Analysis {
  id                String   @id @default(cuid())
  prospectId        String
  prospect          Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  overallScore      Int
  opportunityRating String
  categoryScores    Json
  strengths         Json
  weaknesses        Json
  summary           String
  redesignDirection String
  createdAt         DateTime @default(now())

  @@index([prospectId, createdAt])
  @@unique([prospectId, createdAt])
}

model OutreachDraft {
  id           String   @id @default(cuid())
  prospectId   String
  prospect     Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  subjectLines Json
  conciseBody  String
  detailedBody String
  followUps    Json
  approvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([prospectId, createdAt])
  @@unique([prospectId, createdAt])
}

model PreviewConcept {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  content    Json
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
  @@unique([prospectId, createdAt])
}

model Note {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
}

model Activity {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type       String
  label      String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
}

model StatusHistory {
  id         String          @id @default(cuid())
  prospectId String
  prospect   Prospect        @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  fromStatus ProspectStatus?
  toStatus   ProspectStatus
  createdAt  DateTime        @default(now())

  @@index([prospectId, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  action      String
  subject     String
  windowStart DateTime
  count       Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([action, subject, windowStart])
  @@index([windowStart])
}

model AuditEvent {
  id        String   @id @default(cuid())
  action    String
  outcome   String
  subject   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([outcome, createdAt])
}
